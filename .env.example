# Database connection — Render provides DATABASE_URL automatically
DATABASE_URL=jdbc:postgresql://your-host:5432/your-database
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# Groq AI API key — https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# JWT secret — minimum 32 characters, use a random string
JWT_SECRET=your-very-long-random-secret-key-minimum-32-chars

# Frontend origin allowed by CORS
CORS_ALLOWED_ORIGIN=https://your-frontend.vercel.app

# Server port (optional)
PORT=8080
